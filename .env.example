# Q360 Sandbox API
Q360_BASE_URL=https://rest.q360.online
Q360_API_USERNAME=your_q360_api_username
Q360_API_PASSWORD=your_q360_api_password

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key

# Mock data flag for seed scripts and legacy mock-backed flows.
# Feature 1 now prefers PostgreSQL whenever DATABASE_URL is a PostgreSQL URL.
USE_MOCK_DATA=true

# Database target. Feature 1 reads PostgreSQL here when this is a postgres:// URL.
# Seed tooling still supports either SQLite or PostgreSQL.
DATABASE_URL=file:./mock.db
