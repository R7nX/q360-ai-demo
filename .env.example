# Q360 Sandbox API
Q360_BASE_URL=https://rest.q360.online
Q360_API_USERNAME=your_q360_api_username
Q360_API_PASSWORD=your_q360_api_password

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key

# Mock data flag — set to "true" to use local SQLite DB instead of Q360 API
USE_MOCK_DATA=true

# Database (SQLite for local dev, swap to postgresql:// for AWS RDS)
DATABASE_URL=file:./mock.db
