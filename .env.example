# Q360 Sandbox API
Q360_BASE_URL=http://rest.q360.online
Q360_API_USERNAME=your_q360_api_username
Q360_API_PASSWORD=your_q360_api_password

# Anthropic / Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Mock data flag — set to "true" to use fallback demo data instead of Q360 API
USE_MOCK_DATA=true

# Database (SQLite for local dev, swap to postgresql:// for AWS RDS)
DATABASE_URL=file:./mock.db
